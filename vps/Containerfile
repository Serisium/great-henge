FROM quay.io/fedora/fedora-bootc:43

# Install dev tools and services
RUN dnf install -y \
    tmux \
    vim \
    htop \
    glibc-langpack-en \
    ncurses-term \
    podman \
    passt \
    tailscale \
    nftables \
    openssl \
    wireguard-tools \
    && dnf clean all

# Mirror config trees into the image (after dnf so packaged defaults lose)
COPY etc/ /etc/
COPY usr/ /usr/

# Ghostty sets TERM=xterm-ghostty; ncurses-term only ships the entry as
# "ghostty", so alias it. (A repo symlink won't survive COPY: podman drops
# dangling symlinks from the build context.)
RUN ln -s ../g/ghostty /usr/share/terminfo/x/xterm-ghostty

RUN chmod +x /usr/libexec/pangolin/config-init.sh \
    /usr/libexec/authentik/config-init.sh && \
    systemctl enable \
    tailscaled.service \
    tailscale-auth.service \
    nftables.service \
    pangolin-config-init.service \
    authentik-config-init.service
